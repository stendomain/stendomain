<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Tn.AI — Teman Ngobrol Tech Lau</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Syne:wght@700;800&display=swap" rel="stylesheet"/>
<style>
:root {
  --bg: #f0f4ff;
  --bg2: #e6ecff;
  --surface: #ffffff;
  --border: rgba(99,120,255,0.12);
  --text: #0f1530;
  --text2: #5a6280;
  --text3: #a0a8c0;
  --blue: #4a6cf7;
  --blue2: #6a8eff;
  --blue-soft: rgba(74,108,247,0.10);
  --blue-glow: rgba(74,108,247,0.18);
  --user-bubble: linear-gradient(135deg, #4a6cf7, #6a8eff);
  --ai-bubble: #ffffff;
  --shadow2: 0 2px 12px rgba(0,0,0,0.06);
  --radius: 20px;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;font-family:'Plus Jakarta Sans',sans-serif;background:var(--bg);color:var(--text);-webkit-font-smoothing:antialiased;}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 80% 60% at 10% 0%,rgba(74,108,247,0.08) 0%,transparent 60%),radial-gradient(ellipse 60% 50% at 90% 100%,rgba(106,142,255,0.10) 0%,transparent 55%);pointer-events:none;z-index:0;}

/* LOGIN */
#loginScreen{position:fixed;inset:0;z-index:100;display:flex;align-items:center;justify-content:center;background:var(--bg);padding:1.5rem;}
.login-card{background:var(--surface);border:1px solid var(--border);border-radius:28px;padding:2.8rem 2.2rem;width:100%;max-width:400px;box-shadow:0 8px 48px rgba(74,108,247,0.13);text-align:center;position:relative;overflow:hidden;}
.login-card::before{content:'';position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:200px;height:200px;background:radial-gradient(circle,rgba(74,108,247,0.12) 0%,transparent 70%);pointer-events:none;}
.login-logo{font-family:'Syne',sans-serif;font-size:2.8rem;font-weight:800;background:linear-gradient(135deg,#4a6cf7,#6a8eff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:.3rem;letter-spacing:-1px;}
.login-tagline{font-size:.85rem;color:var(--text2);margin-bottom:2rem;font-weight:400;line-height:1.6;}
.login-tagline strong{color:var(--blue);font-weight:600;}
.google-btn{display:flex;align-items:center;justify-content:center;gap:.7rem;width:100%;padding:.85rem 1.5rem;background:var(--surface);border:1.5px solid var(--border);border-radius:14px;font-family:'Plus Jakarta Sans',sans-serif;font-size:.9rem;font-weight:600;color:var(--text);cursor:pointer;transition:all .2s;box-shadow:var(--shadow2);}
.google-btn:hover{border-color:var(--blue);box-shadow:0 4px 20px var(--blue-glow);transform:translateY(-1px);}
.google-btn:active{transform:scale(.97);}
.google-icon{width:20px;height:20px;flex-shrink:0;}
.login-note{font-size:.72rem;color:var(--text3);margin-top:1.2rem;}

/* APP */
#app{display:none;flex-direction:column;height:100vh;position:relative;z-index:1;}
#app.visible{display:flex;}

/* HEADER */
header{display:flex;align-items:center;justify-content:space-between;padding:.9rem 1.2rem;background:rgba(255,255,255,0.85);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border);flex-shrink:0;position:relative;z-index:10;}
.header-logo{font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:800;background:linear-gradient(135deg,#4a6cf7,#6a8eff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:-.5px;}
.header-status{display:flex;align-items:center;gap:.4rem;font-size:.72rem;color:var(--text2);font-weight:500;}
.status-dot{width:7px;height:7px;border-radius:50%;background:#22c55e;box-shadow:0 0 6px #22c55e;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.4;}}
.header-right{display:flex;align-items:center;gap:.6rem;}
.user-avatar{width:34px;height:34px;border-radius:50%;object-fit:cover;border:2px solid var(--blue-soft);cursor:pointer;}
.logout-btn{background:transparent;border:1px solid var(--border);border-radius:8px;padding:.3rem .7rem;font-family:'Plus Jakarta Sans',sans-serif;font-size:.68rem;font-weight:600;color:var(--text2);cursor:pointer;transition:all .2s;}
.logout-btn:hover{border-color:var(--blue);color:var(--blue);}

/* CHAT */
#chatArea{flex:1;overflow-y:auto;padding:1.2rem 1rem 1rem;scroll-behavior:smooth;-webkit-overflow-scrolling:touch;}
#chatArea::-webkit-scrollbar{width:4px;}
#chatArea::-webkit-scrollbar-thumb{background:var(--blue-soft);border-radius:99px;}

/* WELCOME */
.welcome-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;text-align:center;padding:2rem 1rem;}
.welcome-avatar{width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,#4a6cf7,#6a8eff);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:1.6rem;font-weight:800;color:#fff;margin-bottom:1.2rem;box-shadow:0 8px 32px var(--blue-glow);animation:float 3s ease-in-out infinite;}
@keyframes float{0%,100%{transform:translateY(0);}50%{transform:translateY(-6px);}}
.welcome-title{font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;color:var(--text);margin-bottom:.5rem;letter-spacing:-.3px;}
.welcome-sub{font-size:.85rem;color:var(--text2);line-height:1.7;max-width:280px;font-weight:400;}
.welcome-sub strong{color:var(--blue);font-weight:600;}
.chip-wrap{display:flex;flex-wrap:wrap;gap:.5rem;justify-content:center;margin-top:1.4rem;}
.chip{background:var(--surface);border:1px solid var(--border);border-radius:99px;padding:.38rem .9rem;font-size:.75rem;font-weight:600;color:var(--text2);cursor:pointer;transition:all .2s;box-shadow:var(--shadow2);}
.chip:hover{border-color:var(--blue);color:var(--blue);background:var(--blue-soft);transform:translateY(-1px);}

/* BUBBLES */
.msg-group{margin-bottom:1rem;animation:bubbleIn .3s ease both;}
@keyframes bubbleIn{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
.msg-group.user{display:flex;flex-direction:column;align-items:flex-end;}
.msg-group.ai{display:flex;flex-direction:column;align-items:flex-start;}
.bubble-row{display:flex;align-items:flex-end;gap:.5rem;}
.msg-group.user .bubble-row{flex-direction:row-reverse;}
.ai-ava{width:30px;height:30px;border-radius:50%;flex-shrink:0;background:linear-gradient(135deg,#4a6cf7,#6a8eff);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:.7rem;font-weight:800;color:#fff;box-shadow:0 2px 8px var(--blue-glow);margin-bottom:2px;}
.bubble{max-width:78vw;padding:.75rem 1rem;border-radius:var(--radius);font-size:.88rem;line-height:1.65;font-weight:400;word-break:break-word;}
.msg-group.user .bubble{background:var(--user-bubble);color:#fff;border-bottom-right-radius:5px;box-shadow:0 4px 16px rgba(74,108,247,0.25);}
.msg-group.ai .bubble{background:var(--ai-bubble);color:var(--text);border-bottom-left-radius:5px;border:1px solid var(--border);box-shadow:var(--shadow2);}
.msg-group.ai .bubble strong{color:var(--blue);font-weight:600;}
.msg-group.ai .bubble code{background:var(--bg2);border-radius:5px;padding:.1rem .35rem;font-size:.82rem;font-family:monospace;color:var(--blue);}
.msg-group.ai .bubble pre{background:var(--text);color:#e2e8ff;border-radius:10px;padding:.8rem 1rem;font-size:.78rem;overflow-x:auto;margin:.5rem 0;line-height:1.6;}
.msg-group.ai .bubble pre code{background:none;color:inherit;padding:0;}
.msg-time{font-size:.62rem;color:var(--text3);margin-top:.25rem;padding:0 .2rem;}

/* TYPING */
.typing-bubble{background:var(--ai-bubble);border:1px solid var(--border);border-radius:var(--radius);border-bottom-left-radius:5px;padding:.7rem 1rem;display:inline-flex;gap:.4rem;align-items:center;box-shadow:var(--shadow2);}
.typing-dot{width:7px;height:7px;border-radius:50%;background:var(--blue2);opacity:.4;animation:typingDot 1.2s ease-in-out infinite;}
.typing-dot:nth-child(2){animation-delay:.2s;}
.typing-dot:nth-child(3){animation-delay:.4s;}
@keyframes typingDot{0%,80%,100%{opacity:.2;transform:scale(.8);}40%{opacity:1;transform:scale(1.1);}}

/* INPUT */
#inputArea{padding:.8rem 1rem 1rem;background:rgba(255,255,255,0.9);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-top:1px solid var(--border);flex-shrink:0;}
.input-wrap{display:flex;align-items:flex-end;gap:.6rem;background:var(--surface);border:1.5px solid var(--border);border-radius:18px;padding:.5rem .5rem .5rem .9rem;transition:border-color .2s,box-shadow .2s;box-shadow:var(--shadow2);}
.input-wrap:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px var(--blue-soft);}
#msgInput{flex:1;border:none;outline:none;background:transparent;font-family:'Plus Jakarta Sans',sans-serif;font-size:.88rem;color:var(--text);resize:none;max-height:120px;min-height:24px;line-height:1.5;padding:.3rem 0;}
#msgInput::placeholder{color:var(--text3);}
.send-btn{width:38px;height:38px;border-radius:12px;background:linear-gradient(135deg,#4a6cf7,#6a8eff);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0;box-shadow:0 2px 10px rgba(74,108,247,0.3);}
.send-btn:hover{transform:scale(1.07);}
.send-btn:active{transform:scale(.93);}
.send-btn:disabled{opacity:.4;cursor:not-allowed;transform:none;}
.input-hint{text-align:center;font-size:.65rem;color:var(--text3);margin-top:.5rem;}

/* DRAWER */
#historyBtn{background:transparent;border:1px solid var(--border);border-radius:10px;width:34px;height:34px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;color:var(--text2);}
#historyBtn:hover{border-color:var(--blue);color:var(--blue);}
#historyDrawer{position:fixed;top:0;left:0;bottom:0;width:280px;background:var(--surface);border-right:1px solid var(--border);z-index:200;transform:translateX(-100%);transition:transform .35s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;box-shadow:4px 0 24px rgba(0,0,0,0.08);}
#historyDrawer.open{transform:translateX(0);}
.drawer-overlay{position:fixed;inset:0;background:rgba(0,0,0,.25);z-index:199;opacity:0;pointer-events:none;transition:opacity .3s;}
.drawer-overlay.open{opacity:1;pointer-events:all;}
.drawer-header{padding:1.2rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.drawer-title{font-family:'Syne',sans-serif;font-size:1rem;font-weight:800;color:var(--text);}
.drawer-close{width:28px;height:28px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--text2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.85rem;}
.new-chat-btn{margin:.8rem;padding:.7rem;background:var(--blue-soft);border:1.5px dashed rgba(74,108,247,0.3);border-radius:12px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;font-size:.8rem;font-weight:600;color:var(--blue);display:flex;align-items:center;justify-content:center;gap:.4rem;transition:all .2s;}
.new-chat-btn:hover{background:rgba(74,108,247,0.15);}
#sessionList{flex:1;overflow-y:auto;padding:.4rem .8rem .8rem;}
#sessionList::-webkit-scrollbar{width:3px;}
#sessionList::-webkit-scrollbar-thumb{background:var(--border);border-radius:99px;}
.session-item{padding:.7rem .8rem;border-radius:12px;cursor:pointer;transition:background .2s;margin-bottom:.3rem;border:1px solid transparent;}
.session-item:hover{background:var(--bg2);}
.session-item.active{background:var(--blue-soft);border-color:rgba(74,108,247,0.2);}
.session-title{font-size:.8rem;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.session-date{font-size:.65rem;color:var(--text3);margin-top:.15rem;}
.session-del{float:right;background:none;border:none;color:var(--text3);cursor:pointer;font-size:.75rem;padding:.1rem .3rem;border-radius:4px;transition:color .2s;}
.session-del:hover{color:#ef4444;}

/* TOAST */
.toast{position:fixed;bottom:5rem;left:50%;transform:translateX(-50%) translateY(10px);background:var(--text);color:#fff;border-radius:10px;padding:.5rem 1.1rem;font-size:.78rem;font-weight:500;z-index:999;opacity:0;transition:all .25s;pointer-events:none;white-space:nowrap;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
</style>
</head>
<body>

<div class="toast" id="toast"></div>

<!-- LOGIN -->
<div id="loginScreen">
  <div class="login-card">
    <div class="login-logo">Tn.AI</div>
    <p class="login-tagline">Teman ngobrol tech lau yang<br><strong>chill, jujur, dan ga lebay.</strong></p>
    <button class="google-btn" onclick="loginWithGoogle()">
      <svg class="google-icon" viewBox="0 0 48 48">
        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
      </svg>
      Masuk dengan Google
    </button>
    <p class="login-note">Chat lau tersimpan aman & private per akun 🔒</p>
  </div>
</div>

<!-- APP -->
<div id="app">
  <div class="drawer-overlay" id="drawerOverlay" onclick="closeDrawer()"></div>
  <div id="historyDrawer">
    <div class="drawer-header">
      <span class="drawer-title">Riwayat Chat</span>
      <button class="drawer-close" onclick="closeDrawer()">✕</button>
    </div>
    <button class="new-chat-btn" onclick="newChat()">＋ Chat Baru</button>
    <div id="sessionList"></div>
  </div>

  <header>
    <div style="display:flex;align-items:center;gap:.6rem;">
      <button id="historyBtn" onclick="openDrawer()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
      <div class="header-logo">Tn.AI</div>
    </div>
    <div class="header-status"><div class="status-dot"></div>Tuan online</div>
    <div class="header-right">
      <img class="user-avatar" id="userAvatar" src="" alt=""/>
      <button class="logout-btn" onclick="doLogout()">Keluar</button>
    </div>
  </header>

  <div id="chatArea">
    <div class="welcome-wrap" id="welcomeWrap">
      <div class="welcome-avatar">Tn</div>
      <div class="welcome-title">Yo, gue Tuan! 👋</div>
      <p class="welcome-sub">Tanya apa aja soal <strong>tech</strong> — hardware, software, coding, atau sekadar curhat soal laptop lemot. Gue siap coy!</p>
      <div class="chip-wrap">
        <div class="chip" onclick="sendChip(this)">💻 Rekomendasi laptop</div>
        <div class="chip" onclick="sendChip(this)">🔧 Hardware rusak</div>
        <div class="chip" onclick="sendChip(this)">⚡ Belajar coding</div>
        <div class="chip" onclick="sendChip(this)">📱 Tips & trik HP</div>
        <div class="chip" onclick="sendChip(this)">🌐 Bikin website</div>
      </div>
    </div>
  </div>

  <div id="inputArea">
    <div class="input-wrap">
      <textarea id="msgInput" placeholder="Ketik di sini coy..." rows="1"
        onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
      <button class="send-btn" id="sendBtn" onclick="sendMessage()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </div>
    <div class="input-hint">Tn.AI bisa salah juga — selalu verifikasi info penting ya 🙏</div>
  </div>
</div>

<script type="module">

// ── GANTI INI dengan URL Worker lau setelah deploy ──
const WORKER_URL = 'https://tn-ai-worker.YOUR-SUBDOMAIN.workers.dev/chat';
// contoh: 'https://tn-ai-worker.fadhil.workers.dev/chat'

const FIREBASE_CONFIG = {
  apiKey: "AIzaSyCuqhS_bBh5ijJqb4UXl1Y695fXeY092Zo",
  authDomain: "tn-ai-bb0b8.firebaseapp.com",
  projectId: "tn-ai-bb0b8",
  storageBucket: "tn-ai-bb0b8.firebasestorage.app",
  messagingSenderId: "960261927968",
  appId: "1:960261927968:web:14b338a9ccc826af0fb845"
};

const SYSTEM_PROMPT = `Lau adalah Tuan (Tn.AI) — asisten AI tech yang chill, humoris, dan jujur.
Gaya bicara lau:
- Selalu pake "Gue" untuk diri sendiri, "Lau" untuk user
- Sering pake kata "Coy" di akhir atau tengah kalimat
- Santai tapi tetap informatif dan akurat
- Kalau ada yang ga tau, jujur aja bilang ga tau
- Spesialis tech: hardware, software, coding, gadget, networking, dll
- Sesekali kasih humor ringan tapi ga berlebihan
- Jawab pake bahasa Indonesia gaul yang natural
- Format jawaban rapi pakai bold untuk poin penting`;

import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getAuth, signInWithPopup, GoogleAuthProvider, signOut, onAuthStateChanged }
  from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";
import { getFirestore, collection, doc, addDoc, updateDoc, deleteDoc,
  getDocs, orderBy, query, serverTimestamp }
  from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

const fbApp    = initializeApp(FIREBASE_CONFIG);
const auth     = getAuth(fbApp);
const db       = getFirestore(fbApp);
const provider = new GoogleAuthProvider();

let currentUser = null, currentSessionId = null;
let sessions = [], chatHistory = [], isLoading = false;

onAuthStateChanged(auth, async user => {
  if (user) {
    currentUser = user;
    document.getElementById('loginScreen').style.display = 'none';
    document.getElementById('app').classList.add('visible');
    document.getElementById('userAvatar').src = user.photoURL || '';
    await loadSessions();
    if (!currentSessionId) await newChat();
  } else {
    currentUser = null;
    document.getElementById('loginScreen').style.display = 'flex';
    document.getElementById('app').classList.remove('visible');
  }
});

window.loginWithGoogle = async () => {
  try { await signInWithPopup(auth, provider); }
  catch(e) { showToast('Gagal login: ' + e.message); }
};
window.doLogout = async () => {
  await signOut(auth);
  currentSessionId = null; sessions = []; chatHistory = [];
};

async function loadSessions() {
  if (!currentUser) return;
  const snap = await getDocs(query(
    collection(db,'users',currentUser.uid,'sessions'), orderBy('updatedAt','desc')
  ));
  sessions = snap.docs.map(d => ({ id: d.id, ...d.data() }));
  renderSessionList();
}

async function newChat() {
  if (!currentUser) return;
  const docRef = await addDoc(collection(db,'users',currentUser.uid,'sessions'), {
    title:'Chat baru', createdAt:serverTimestamp(), updatedAt:serverTimestamp(), messages:[]
  });
  currentSessionId = docRef.id; chatHistory = [];
  sessions.unshift({ id:docRef.id, title:'Chat baru', messages:[] });
  renderSessionList(); clearChatUI(); closeDrawer();
}
window.newChat = newChat;

async function loadSession(id) {
  currentSessionId = id;
  const s = sessions.find(x => x.id === id);
  if (!s) return;
  chatHistory = s.messages || [];
  clearChatUI();
  chatHistory.forEach(m => renderBubble(m.role==='user'?'user':'ai', m.parts[0].text, false));
  scrollToBottom(); renderSessionList(); closeDrawer();
}

async function saveMessage(role, text) {
  if (!currentUser || !currentSessionId) return;
  const msg = { role, parts:[{text}] };
  chatHistory.push(msg);
  const s = sessions.find(x => x.id === currentSessionId);
  if (s) {
    s.messages = chatHistory;
    if (chatHistory.length===1) s.title = text.substring(0,40)+(text.length>40?'...':'');
  }
  await updateDoc(doc(db,'users',currentUser.uid,'sessions',currentSessionId), {
    messages:chatHistory, title:s?.title||'Chat', updatedAt:serverTimestamp()
  });
  renderSessionList();
}

async function deleteSession(id, e) {
  e.stopPropagation();
  if (!confirm('Hapus chat ini coy?')) return;
  await deleteDoc(doc(db,'users',currentUser.uid,'sessions',id));
  sessions = sessions.filter(s => s.id !== id);
  if (currentSessionId===id) {
    if (sessions.length>0) await loadSession(sessions[0].id);
    else await newChat();
  }
  renderSessionList();
}
window.deleteSession = deleteSession;

function renderSessionList() {
  const el = document.getElementById('sessionList');
  if (!sessions.length) {
    el.innerHTML='<div style="text-align:center;color:var(--text3);font-size:.75rem;padding:1rem;">Belum ada chat coy</div>';
    return;
  }
  el.innerHTML = sessions.map(s=>`
    <div class="session-item ${s.id===currentSessionId?'active':''}" onclick="loadSessionById('${s.id}')">
      <button class="session-del" onclick="deleteSession('${s.id}',event)">🗑</button>
      <div class="session-title">${escH(s.title||'Chat')}</div>
      <div class="session-date">${s.updatedAt?.toDate?s.updatedAt.toDate().toLocaleDateString('id-ID'):''}</div>
    </div>`).join('');
}
window.loadSessionById = id => loadSession(id);

// ── CALL WORKER (bukan Groq langsung) ───────────────────
async function callWorker(text) {
  const messages = [
    { role:'system', content:SYSTEM_PROMPT },
    ...chatHistory.slice(0,-1).map(m=>({
      role: m.role==='model'?'assistant':m.role,
      content: m.parts[0].text
    })),
    { role:'user', content:text }
  ];

  const res = await fetch(WORKER_URL, {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({ messages })
  });

  const data = await res.json();
  if (!res.ok) throw new Error(data.error || 'Worker error ' + res.status);
  return data.reply || 'Hmm ga ada respons coy, coba lagi ya.';
}

// ── SEND ─────────────────────────────────────────────────
async function sendMessage(text) {
  const input = document.getElementById('msgInput');
  const msg   = (text || input.value).trim();
  if (!msg || isLoading) return;
  if (!text) input.value = '';
  autoResize(input);

  document.getElementById('welcomeWrap')?.remove();
  isLoading = true;
  document.getElementById('sendBtn').disabled = true;

  renderBubble('user', msg);
  await saveMessage('user', msg);

  const typingId = showTyping();
  try {
    const reply = await callWorker(msg);
    removeTyping(typingId);
    renderBubble('ai', reply);
    await saveMessage('model', reply);
  } catch(e) {
    removeTyping(typingId);
    renderBubble('ai', '😅 ' + e.message);
  }
  isLoading = false;
  document.getElementById('sendBtn').disabled = false;
  scrollToBottom();
}
window.sendMessage = sendMessage;
window.sendChip = el => sendMessage(el.textContent.replace(/^[^ ]+ /,''));

function renderBubble(role, text, animate=true) {
  const area  = document.getElementById('chatArea');
  const group = document.createElement('div');
  group.className = `msg-group ${role}`;
  if (!animate) group.style.animation = 'none';
  const now = new Date().toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'});
  if (role==='ai') {
    group.innerHTML = `
      <div class="bubble-row">
        <div class="ai-ava">Tn</div>
        <div class="bubble">${formatText(text)}</div>
      </div>
      <div class="msg-time">${now}</div>`;
  } else {
    group.innerHTML = `
      <div class="bubble-row">
        <div class="bubble">${escH(text)}</div>
      </div>
      <div class="msg-time">${now}</div>`;
  }
  area.appendChild(group);
  if (animate) scrollToBottom();
}

function formatText(t) {
  return t
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/```(\w*)\n?([\s\S]*?)```/g,'<pre><code>$2</code></pre>')
    .replace(/`([^`]+)`/g,'<code>$1</code>')
    .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
    .replace(/\*(.*?)\*/g,'<em>$1</em>')
    .replace(/\n/g,'<br>');
}

function showTyping() {
  const area = document.getElementById('chatArea');
  const id   = 'typing-'+Date.now();
  const wrap = document.createElement('div');
  wrap.id=id; wrap.className='msg-group ai';
  wrap.innerHTML=`<div class="bubble-row"><div class="ai-ava">Tn</div><div class="typing-bubble"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div></div>`;
  area.appendChild(wrap); scrollToBottom(); return id;
}
function removeTyping(id) { document.getElementById(id)?.remove(); }

function clearChatUI() {
  const area = document.getElementById('chatArea');
  area.innerHTML = '';
  if (!chatHistory.length) {
    area.innerHTML=`<div class="welcome-wrap" id="welcomeWrap">
      <div class="welcome-avatar">Tn</div>
      <div class="welcome-title">Yo, gue Tuan! 👋</div>
      <p class="welcome-sub">Tanya apa aja soal <strong>tech</strong> — hardware, software, coding, atau sekadar curhat soal laptop lemot. Gue siap coy!</p>
      <div class="chip-wrap">
        <div class="chip" onclick="sendChip(this)">💻 Rekomendasi laptop</div>
        <div class="chip" onclick="sendChip(this)">🔧 Hardware rusak</div>
        <div class="chip" onclick="sendChip(this)">⚡ Belajar coding</div>
        <div class="chip" onclick="sendChip(this)">📱 Tips & trik HP</div>
        <div class="chip" onclick="sendChip(this)">🌐 Bikin website</div>
      </div>
    </div>`;
  }
}

function scrollToBottom() {
  const a = document.getElementById('chatArea');
  setTimeout(()=>a.scrollTo({top:a.scrollHeight,behavior:'smooth'}),50);
}

window.openDrawer  = ()=>{ document.getElementById('historyDrawer').classList.add('open'); document.getElementById('drawerOverlay').classList.add('open'); };
window.closeDrawer = ()=>{ document.getElementById('historyDrawer').classList.remove('open'); document.getElementById('drawerOverlay').classList.remove('open'); };
window.handleKey   = e=>{ if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMessage();} };
window.autoResize  = el=>{ el.style.height='auto'; el.style.height=Math.min(el.scrollHeight,120)+'px'; };
function escH(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3000);}
window.showToast=showToast;
</script>
